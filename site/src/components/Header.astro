---
import { u, BASE } from '../lib/format';
// Shared top bar, rendered once from Base.astro so every page is identical.
// Compare base-relative paths so `active` works at the root and under a subpath.
const path = (Astro.url.pathname.slice(BASE.length).replace(/\/+$/, '') || '/');
const links = [
  { href: '/archive', label: "L'archive", reload: false },
  { href: '/collections', label: 'Collections', reload: false },
  { href: '/projet', label: 'Le projet', reload: false },
  { href: '/recherche', label: 'Rechercher', reload: false },
];
const active = (href: string) => path === href || path.startsWith(href + '/');
---
<header class="site-header">
  <div class="bar">
    <a class="brand" href={u('/')}>Écrivanalyse</a>
    <nav>
      {links.map((l) => (
        <a href={u(l.href)} class:list={['navlink', { active: active(l.href) }]} {...(l.reload ? { 'data-astro-reload': true } : {})}>{l.label}</a>
      ))}
      <button class="iconbtn" onclick="toggleTheme()" title="Jour / Nuit" aria-label="Jour / Nuit"><span class="tomoon">☾</span><span class="tosun">☀︎</span></button>
    </nav>
  </div>
</header>

<style>
  .site-header { width: 100%; }
  .bar {
    max-width: 760px; margin: 0 auto;
    padding: clamp(18px, 3.4vw, 26px) clamp(20px, 5vw, 32px);
    display: flex; justify-content: space-between; align-items: center; gap: 20px;
  }
  .brand {
    font-family: var(--font-serif); font-size: 20px; letter-spacing: .01em;
    text-decoration: none; color: var(--color-ink);
  }
  nav { display: flex; gap: clamp(14px, 2.2vw, 24px); align-items: center;
    font-size: 13.5px; color: var(--color-muted); }
  /* padding + equal negative margin: comfortable touch targets, zero layout shift */
  .navlink { text-decoration: none; color: var(--color-muted); white-space: nowrap;
    padding: 12px 4px; margin: -12px -4px; }
  .navlink:hover { color: var(--color-ocre); }
  .navlink.active { color: var(--color-ink); }
  .iconbtn { background: none; border: none; cursor: pointer; color: var(--color-muted);
    font-size: 15px; font-family: var(--font-sans); line-height: 1;
    padding: 12px 10px; margin: -12px -10px; }
  /* the glyph names the destination: ☾ invites the night, ☀︎ the day */
  .iconbtn .tosun { display: none; }
  :global(:root[data-theme="dark"]) .iconbtn .tosun { display: inline; }
  :global(:root[data-theme="dark"]) .iconbtn .tomoon { display: none; }
  .iconbtn:hover { color: var(--color-ocre); }

  @media (max-width: 560px) {
    .bar { flex-direction: column; align-items: flex-start; gap: 12px; }
    nav { flex-wrap: wrap; gap: 16px; }
  }
</style>
