---
import { getCollection } from 'astro:content';

// Every quinte that has its own page (mirrors getStaticPaths in quinte/[id].astro).
const ids = (await getCollection('quintes'))
  .filter((q) => q.data.lines.length > 0)
  .map((q) => q.id);
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Une quinte au hasard…</title>
    <script type="application/json" id="ea-ids" set:html={JSON.stringify(ids)}></script>
    <script is:inline>
      (function () {
        try {
          var ids = JSON.parse(document.getElementById('ea-ids').textContent);
          if (ids && ids.length) {
            // replace() so /hasard never lands in history — Back returns where you were.
            location.replace('/quinte/' + ids[Math.floor(Math.random() * ids.length)]);
            return;
          }
        } catch (e) {}
        location.replace('/archive');
      })();
    </script>
    <style>
      html { background: #F6F1E7; }
      @media (prefers-color-scheme: dark) { html { background: #1E1A16; } }
      body { margin: 0; min-height: 100vh; display: grid; place-items: center;
        font-family: Georgia, serif; font-style: italic; color: #6B635A; }
    </style>
  </head>
  <body>
    <p>une quinte au hasard…</p>
    <noscript><a href="/archive">Parcourir l'archive</a></noscript>
  </body>
</html>
