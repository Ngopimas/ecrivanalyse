---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { year, roleLabel, u } from '../lib/format';

// quintes (incl. the ghost séance records, which have a page but no lines
// online) and the textes, one chronology
const all = [
  ...(await getCollection('quintes'))
    .filter((q) => q.data.lines.length > 0 || q.data.participant_role)
    .map((q) => ({ kind: 'quinte', id: q.id, data: q.data })),
  ...(await getCollection('textes'))
    .map((t) => ({ kind: 'texte', id: t.id, data: t.data })),
].sort((a, b) => (b.data.id ?? 0) - (a.data.id ?? 0));

// group by year (desc)
const byYear = new Map<string, typeof all>();
for (const q of all) {
  const y = year(q.data.date);
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(q);
}
const years = [...byYear.keys()].sort((a, b) => b.localeCompare(a));
const total = all.length;
const nQuintes = all.filter((q) => q.kind === 'quinte').length;
const nTextes = total - nQuintes;
const nPause = all.filter((q) => q.kind === 'quinte' && q.data.mode === 'pause').length;
const nEcri = all.filter((q) => q.kind === 'quinte' && q.data.mode === 'ecrivanalyse').length;
---
<Base title="L'archive - Écrivanalyse">
  <div class="wrap">
    <main>
      <h1>L'archive</h1>
      <p class="lede">{nQuintes.toLocaleString('fr-FR').replace(/[  ]/g, ' ')} quintes et {nTextes} textes, archivés de {years[years.length - 1]} à {years[0]}.</p>

      <div class="facets" role="group" aria-label="Filtrer par mode">
        <button class="facet on" data-f="all">tout · {total}</button>
        <button class="facet" data-f="pause">séances de p(au)se · {nPause}</button>
        <button class="facet" data-f="ecrivanalyse">écrivanalyse · {nEcri}</button>
        <button class="facet" data-f="texte">textes · {nTextes}</button>
      </div>

      <nav class="years" aria-label="Aller à une année">
        {years.map((y) => <a href={`#y-${y}`}>{y}</a>)}
      </nav>

      {years.map((y) => (
        <section class="yr" id={`y-${y}`} style={`--h:${byYear.get(y)!.length * 70 + 60}px`}>
          <h2>{y}</h2>
          <ul>
            {byYear.get(y)!.map((q) => (
              <li data-mode={q.kind === 'texte' ? 'texte' : (q.data.mode || 'none')}>
                <a href={u(`/${q.kind}/${q.id}`)}>
                  <span class="entry">
                    <span class="t" data-vt-title>{q.data.title}</span>
                    {q.data.soustitre && <span class="d">{q.data.soustitre}</span>}
                  </span>
                  <span class="r">{q.kind === 'texte' ? 'texte' : roleLabel(q.data.participant_role)}{q.data.quintesse_num ? ` · ${q.data.quintesse_num}` : ''}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </main>
  </div>

  <script is:inline data-astro-rerun>
    (() => {
      // Year jumps: with content-visibility, unrendered sections sit at their
      // estimated height, so a one-shot anchor jump lands off-target. Re-run
      // scrollIntoView for a few frames while the real layout settles.
      document.querySelectorAll('.years a').forEach((a) => a.addEventListener('click', (e) => {
        const el = document.querySelector(a.getAttribute('href'));
        if (!el) return;
        e.preventDefault();
        history.replaceState(null, '', a.getAttribute('href'));
        document.querySelectorAll('.years a').forEach((x) => x.classList.toggle('on', x === a));
        a.parentElement.scrollTo({ left: a.offsetLeft - 24, behavior: 'smooth' });
        let n = 0;
        (function settle() {
          el.scrollIntoView();
          if (++n < 6) requestAnimationFrame(settle);
        })();
      }));

      // the rail follows the reading: as a year's section crosses the upper
      // band of the viewport, its link lights up and slides into view
      const rail = document.querySelector('.years');
      if (rail && 'IntersectionObserver' in window) {
        const byYear = new Map([...rail.querySelectorAll('a')]
          .map((a) => [a.getAttribute('href').slice(1), a]));
        let current = '';
        const io = new IntersectionObserver((entries) => {
          const tops = entries.filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (!tops.length) return;
          const y = tops[0].target.id;
          if (y === current) return;
          current = y;
          const a = byYear.get(y);
          if (!a) return;
          byYear.forEach((x) => x.classList.toggle('on', x === a));
          rail.scrollTo({ left: a.offsetLeft - 24, behavior: 'smooth' });
        }, { rootMargin: '-46px 0px -70% 0px' });
        document.querySelectorAll('.yr').forEach((s) => io.observe(s));
      }

      const btns = document.querySelectorAll('.facet');
      btns.forEach((b) => b.addEventListener('click', () => {
        btns.forEach((x) => x.classList.remove('on'));
        b.classList.add('on');
        const f = b.getAttribute('data-f');
        document.querySelectorAll('.yr li').forEach((li) => {
          const show = f === 'all' || li.getAttribute('data-mode') === f;
          li.style.display = show ? '' : 'none';
        });
        document.querySelectorAll('.yr').forEach((s) => {
          const any = [...s.querySelectorAll('li')].some((li) => li.style.display !== 'none');
          s.style.display = any ? '' : 'none';
        });
      }));
    })();
  </script>

  <style>
    .wrap { max-width: 760px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 32px) 80px; }
    h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(28px, 5vw, 42px);
      letter-spacing: -.01em; margin: clamp(18px, 4vw, 32px) 0 12px; }
    .lede { color: var(--color-muted); font-size: 15px; margin: 0 0 24px; }
    .facets { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 40px; }
    .facet { font-family: var(--font-mono); font-size: 12px; cursor: pointer; color: var(--color-muted);
      background: none; border: 1px solid var(--color-hair); border-radius: 999px; padding: 7px 14px; }
    .facet:hover { border-color: var(--color-ocre); color: var(--color-ocre); }
    .facet.on { border-color: var(--color-ocre); color: var(--color-ocre); background: color-mix(in srgb, var(--color-ocre) 8%, transparent); }

    /* sticky year rail: ~3 000 entries make one very long page; this is the map */
    .years { position: sticky; top: 0; z-index: 5; display: flex;
      gap: clamp(10px, 1.4vw, 12px); justify-content: space-between;
      overflow-x: auto; scrollbar-width: none; background: var(--color-paper);
      font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .02em;
      padding: 12px 2px 10px; margin: 0 0 30px; border-bottom: 1px solid var(--color-hair); }
    .years::-webkit-scrollbar { display: none; }
    .years a { color: var(--color-muted); text-decoration: none; padding: 8px 0; margin: -8px 0; }
    .years a:hover, .years a.on { color: var(--color-ocre); }

    /* offscreen years skip layout & paint — the page holds 3 000+ rows.
       --h estimates the section's real height (rows × ~70px) so anchor jumps
       land close; the rail's settle loop corrects the rest. */
    .yr { margin-bottom: 34px; content-visibility: auto;
      contain-intrinsic-size: auto var(--h, 900px); scroll-margin-top: 46px; }
    .yr h2 { font-family: var(--font-mono); font-size: 12px; letter-spacing: .14em; color: var(--color-ocre);
      border-bottom: 1px solid var(--color-hair); padding-bottom: 8px; margin: 0 0 4px; }
    .yr ul { list-style: none; margin: 0; padding: 0; }
    .yr li a { display: flex; justify-content: space-between; gap: 24px; align-items: baseline;
      text-decoration: none; padding: 11px 2px; border-bottom: 1px solid color-mix(in srgb, var(--color-hair) 55%, transparent); }
    .yr li a:hover .t { color: var(--color-ocre); }
    .yr .entry { display: flex; flex-direction: column; gap: 3px; min-width: 0;
      transition: transform .35s cubic-bezier(.2, .65, .25, 1); }
    .yr li a:hover .entry { transform: translateX(3px); }
    .yr .t { font-family: var(--font-serif); font-size: 17px; }
    .yr .d { font-family: var(--font-serif); font-style: italic; font-size: 13.5px;
      color: var(--color-muted); line-height: 1.35; }
    .yr .r { font-family: var(--font-mono); font-size: 10.5px; color: var(--color-muted); white-space: nowrap; }
  </style>
</Base>
