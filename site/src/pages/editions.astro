---
import Base from '../layouts/Base.astro';
import { proseHtml, slug, u } from '../lib/format';
import pages from '../data/legacy-pages.json';

// Les éditions - Ivan Joseph's self-publishing story, in his own pages from
// the original site (extracted to legacy-pages.json by gen-content.py):
// the ÉOK introduction (14), the Éditions Omar Kaczmar books (123-125), and
// the Éditions Œuvres Komplètes side (127, 797). 797 presents the recueil
// « Faire une quinte de tout » the ghost quinte pages point to.
const intro = pages['14'];
const oka = ['123', '124', '125'].map((id) => pages[id]);
const oek = ['127', '797'].map((id) => pages[id]);

// the review of « Faire une quinte de tout » is signed Manunews, the blog of
// Emmanuelle Waechter - the signature links to the source post
const MANUNEWS =
  'https://emmanuellewaechter.blogspot.com/2012/03/parution-imminente-du-recueil-faire-une.html';
const html = (b: (typeof pages)['14']) => {
  const h = proseHtml(b.text);
  return b === pages['797']
    ? h.replace('<p>Manunews</p>',
      `<p><a href="${MANUNEWS}" target="_blank" rel="noopener">Manunews</a></p>`)
    : h;
};
---
<Base
  title="Les éditions - Écrivanalyse"
  description="Des Éditions Omar Kaczmar aux Éditions Œuvres Komplètes : l’aventure éditoriale d’Ivan Joseph, et le recueil « Faire une quinte de tout »."
>
  <div class="wrap">
    <main data-pagefind-body>
      <h1>Les éditions</h1>
      {intro.soustitre && <p class="lede">{intro.soustitre}</p>}
      <div class="texte intro" set:html={html(intro)} />

      <section>
        <h2>Des Éditions Omar Kaczmar d’hier...</h2>
        {oka.map((b) => (
          <article id={slug(b.title)}>
            <h3>{b.title}</h3>
            {b.soustitre && <p class="sous">{b.soustitre}</p>}
            <div class="texte" set:html={html(b)} />
          </article>
        ))}
      </section>

      <section>
        <h2>... aux Éditions Œuvres Komplètes d’aujourd’hui</h2>
        {oek.map((b) => (
          <article id={slug(b.title)}>
            <h3>{b.title}</h3>
            {b.soustitre && <p class="sous">{b.soustitre}</p>}
            <div class="texte" set:html={html(b)} />
          </article>
        ))}
      </section>

      <div class="object">
        <div>Ivan Joseph</div>
        <a class="gloss" href={u('/projet')}>← Le projet</a>
      </div>
    </main>
  </div>

  <style>
    .wrap { max-width: 680px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 32px) 80px; }
    h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(28px, 5vw, 42px);
      letter-spacing: -.01em; margin: clamp(18px, 4vw, 32px) 0 10px; }
    .lede { font-family: var(--font-serif); font-style: italic; color: var(--color-muted);
      font-size: clamp(15px, 2.2vw, 17px); margin: 0 0 24px; }
    .intro { margin-bottom: 44px; }
    section { margin: 0 0 44px; }
    h2 { font-family: var(--font-mono); font-weight: 400; font-size: 12px; letter-spacing: .1em;
      color: var(--color-ocre); border-bottom: 1px solid var(--color-hair);
      padding-bottom: 8px; margin: 0 0 24px; }
    article { margin: 0 0 36px; scroll-margin-top: 20px; }
    h3 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(20px, 3vw, 25px);
      letter-spacing: -.01em; margin: 0 0 4px; }
    .sous { font-family: var(--font-serif); font-style: italic; color: var(--color-muted);
      font-size: 15.5px; margin: 0 0 12px; }
    .texte { font-family: var(--font-serif); font-size: clamp(16px, 2.2vw, 18px); line-height: 1.72; }
    .texte :global(p) { margin: 0 0 1em; }
    .texte :global(a) { color: var(--color-ocre); text-decoration: none; }
    .texte :global(a:hover) { text-decoration: underline; text-underline-offset: 3px; }
    .object { font-family: var(--font-mono); font-size: 12px; color: var(--color-muted);
      border-top: 1px solid var(--color-hair); padding-top: 20px; line-height: 1.9;
      display: flex; justify-content: space-between; align-items: baseline; }
    .gloss { color: var(--color-ocre); text-decoration: none; }
    .gloss:hover { text-decoration: underline; text-underline-offset: 3px; }
  </style>
</Base>
