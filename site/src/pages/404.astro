---
import { readFileSync } from 'node:fs';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { u, slug, BASE } from '../lib/format';
// The 404 borrows the quintesse status vocabulary (open and playful, DESIGN.md):
// a missing page is a quintesse whose fate is unknown.
//
// It also carries the memory of the old site: twenty years of links point at
// spip.php?articleN / rubriqueN. Article ids were kept identical, so the
// inline script forwards them (quinte, else texte); rubriques map to the
// collection slugs embedded below.
const quints = JSON.parse(readFileSync(
  new URL('../../../ecrivanalyse-backup/data/quintesses.json', import.meta.url), 'utf8'));
const known = new Set([
  ...(await getCollection('quintes')).map((q) => slug(q.data.collection)),
  ...(await getCollection('textes')).map((t) => slug(t.data.collection)),
]);
const rubriqueMap: Record<number, string> = {};
for (const q of quints) {
  if (!q.rubrique_id || !q.collection) continue;
  const s = slug(q.collection);
  if (known.has(s)) rubriqueMap[q.rubrique_id] = s;
}
---
<Base title="Page introuvable - Écrivanalyse">
  <div class="wrap">
    <main>
      <div class="kicker">page introuvable</div>
      <h1>Cette page s'est dérobée.</h1>
      <p class="body">
        Peut-être troquée, suspendue, offerte - ou détruite pour de bon.
        Les quintes, elles, sont toujours là.
      </p>
      <nav class="paths" aria-label="Continuer">
        <a class="rand" href={u('/hasard')} data-astro-reload>rencontre au hasard&nbsp;↻</a>
        <a href={u('/archive')}>parcourir l'archive</a>
        <a href={u('/recherche')} data-astro-reload>chercher un mot</a>
      </nav>
    </main>
  </div>

  <script type="application/json" id="ea-legacy" data-base={BASE} set:html={JSON.stringify(rubriqueMap)}></script>
  <script is:inline>
    (function () {
      // old SPIP addresses: spip.php?article154, ?rubrique54, ?auteur19,
      // spip.php?page=forum&id_article=154 - forward them to their new homes
      var el = document.getElementById('ea-legacy');
      if (!el) return;
      var base = el.dataset.base || '';
      var q = location.pathname + location.search;
      var m = /article=?(\d+)/.exec(q);
      if (m) {
        var id = m[1];
        // same ids as the old site: try the quinte page, then the texte
        fetch(base + '/quinte/' + id + '/', { method: 'HEAD' }).then(function (r) {
          if (r.ok) { location.replace(base + '/quinte/' + id); return; }
          return fetch(base + '/texte/' + id + '/', { method: 'HEAD' }).then(function (r2) {
            if (r2 && r2.ok) location.replace(base + '/texte/' + id);
          });
        }).catch(function () {});
        return;
      }
      m = /rubrique(\d+)/.exec(q);
      if (m) {
        var map = {};
        try { map = JSON.parse(el.textContent); } catch (e) {}
        if (map[m[1]]) location.replace(base + '/collection/' + map[m[1]]);
        return;
      }
      if (/auteur\d+/.test(q)) location.replace(base + '/projet');
    })();
  </script>

  <style>
    .wrap { max-width: 760px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 32px) 80px;
      flex: 1; display: flex; }
    main { margin: auto; text-align: center; padding-bottom: 8vh; }
    .kicker { font-family: var(--font-mono); font-size: 11px; letter-spacing: .16em;
      text-transform: uppercase; color: var(--color-muted); margin-bottom: 22px; }
    h1 { font-family: var(--font-serif); font-weight: 400; font-style: italic;
      font-size: clamp(30px, 6vw, 48px); letter-spacing: -.012em; margin: 0 0 16px; }
    .body { font-family: var(--font-serif); font-size: clamp(15px, 2.2vw, 17.5px);
      color: var(--color-muted); max-width: 44ch; margin: 0 auto 44px; line-height: 1.65; }
    .paths { display: flex; flex-direction: column; align-items: center; gap: 18px; }
    .paths a { font-family: var(--font-mono); font-size: 13px; color: var(--color-muted);
      text-decoration: none; padding: 4px 2px; }
    .paths a:hover { color: var(--color-ocre); }
    .paths .rand { color: var(--color-ocre); border: 1px solid var(--color-ocre);
      border-radius: 999px; padding: 10px 20px; letter-spacing: .02em;
      transition: background .2s, color .2s; }
    .paths .rand:hover { background: var(--color-ocre); color: var(--color-paper); }
  </style>
</Base>
