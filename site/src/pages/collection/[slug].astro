---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { slug, roleLabel, modeLabel, year, u } from '../../lib/format';

export async function getStaticPaths() {
  // quintes (incl. the ghost séance records) and textes, one merged list per série
  const all = [
    ...(await getCollection('quintes'))
      .filter((q) => (q.data.lines.length > 0 || q.data.participant_role) && q.data.collection)
      .map((q) => ({ kind: 'quinte', id: q.id, data: q.data })),
    ...(await getCollection('textes'))
      .filter((t) => t.data.collection)
      .map((t) => ({ kind: 'texte', id: t.id, data: t.data })),
  ];
  const map = new Map<string, { name: string; mode: string | null; items: typeof all }>();
  for (const q of all) {
    const s = slug(q.data.collection);
    if (!map.has(s)) map.set(s, { name: q.data.collection!, mode: q.data.mode, items: [] });
    const v = map.get(s)!;
    v.items.push(q);
    if (!v.mode) v.mode = q.data.mode; // first non-empty mode names the série
  }
  return [...map.entries()].map(([s, v]) => ({
    params: { slug: s },
    props: { name: v.name, mode: v.mode, items: v.items.sort((a, b) => (b.data.id ?? 0) - (a.data.id ?? 0)) },
  }));
}

const { name, mode, items } = Astro.props;
const nQ = items.filter((i) => i.kind === 'quinte').length;
const nT = items.length - nQ;
const countLabel = [nQ ? `${nQ} quinte${nQ > 1 ? 's' : ''}` : '', nT ? `${nT} texte${nT > 1 ? 's' : ''}` : '']
  .filter(Boolean).join(' · ');
---
<Base title={`« ${name} » - Écrivanalyse`}>
  <div class="wrap">
    <main>
      <h1 transition:name="qtitle">«&#8239;{name}&#8239;»</h1>
      <div class="breadcrumb"><a href={u('/collections')}>← Collections</a>{modeLabel(mode) && <span> · {modeLabel(mode)}</span>} · {countLabel}</div>
      <ul>
        {items.map((q) => (
          <li>
            <a href={u(`/${q.kind}/${q.id}`)}>
              <span class="t" data-vt-title>{q.data.title}</span>
              <span class="r">{year(q.data.date)}{q.kind === 'texte' ? ' · texte' : ''}{q.data.quintesse_num ? ` · ${q.data.quintesse_num}` : ''}</span>
            </a>
          </li>
        ))}
      </ul>
    </main>
  </div>

  <style>
    .wrap { max-width: 760px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 32px) 80px; }
    header { display: flex; justify-content: space-between; align-items: center; padding: clamp(20px, 4vw, 34px) 0; }
    .brand { font-family: var(--font-serif); font-size: 19px; text-decoration: none; }
    header nav { display: flex; gap: 20px; align-items: center; font-size: 13.5px; color: var(--color-muted); }
    header nav a { text-decoration: none; } header nav a:hover { color: var(--color-ocre); }
    .iconbtn { background: none; border: none; cursor: pointer; color: var(--color-muted); font-size: 15px; }
    .breadcrumb { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; color: var(--color-muted); margin: 0 0 28px; }
    .breadcrumb a { color: var(--color-ocre); text-decoration: none; }
    h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(28px, 5vw, 42px);
      letter-spacing: -.01em; margin: clamp(18px, 4vw, 32px) 0 10px; }
    ul { list-style: none; margin: 0; padding: 0; }
    li a { display: flex; justify-content: space-between; gap: 20px; align-items: baseline; text-decoration: none;
      padding: 10px 2px; border-bottom: 1px solid color-mix(in srgb, var(--color-hair) 60%, transparent); }
    li a:hover { color: var(--color-ocre); }
    .t { font-family: var(--font-serif); font-size: 18px; display: inline-block;
      transition: transform .35s cubic-bezier(.2, .65, .25, 1); }
    li a:hover .t { transform: translateX(3px); }
    .r { font-family: var(--font-mono); font-size: 10.5px; color: var(--color-muted); white-space: nowrap; }
  </style>
</Base>
