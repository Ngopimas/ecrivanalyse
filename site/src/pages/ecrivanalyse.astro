---
import Base from '../layouts/Base.astro';
import { proseHtml, slug, u } from '../lib/format';
import pages from '../data/legacy-pages.json';

// « Qu'est-ce que l'écrivanalyse ? » - the presentation of the practice in
// five chapters, written by Perrine Tamerlis for the original site
// (articles 129-134, extracted to legacy-pages.json by gen-content.py).
const chapters = ['129', '130', '131', '132', '134'].map((id) => pages[id]);
const author = chapters[0].author;
const year = (chapters[0].date || '').slice(0, 4);
---
<Base
  title="Qu’est-ce que l’écrivanalyse ? - Écrivanalyse"
  description="La pratique d’Ivan Joseph présentée en cinq chapitres par Perrine Tamerlis : une expérience de création littéraire d’inspiration psychanalytique."
>
  <div class="wrap">
    <main data-pagefind-body>
      <h1>Qu’est-ce que l’écrivanalyse&#8239;?</h1>
      <p class="lede" data-pagefind-ignore>La pratique présentée en cinq chapitres, par Perrine Tamerlis.</p>

      {chapters.map((c) => (
        <section id={slug(c.title)}>
          <h2>{c.title}</h2>
          {c.soustitre && <p class="sous">{c.soustitre}</p>}
          <div class="texte" set:html={proseHtml(c.text)} />
        </section>
      ))}

      <div class="object">
        <div>{author}{year ? ` · ${year}` : ''}</div>
        <a class="gloss" href={u('/projet')}>← Le projet</a>
      </div>
    </main>
  </div>

  <style>
    .wrap { max-width: 680px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 32px) 80px; }
    h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(28px, 5vw, 42px);
      letter-spacing: -.01em; margin: clamp(18px, 4vw, 32px) 0 10px; }
    .lede { font-family: var(--font-serif); font-style: italic; color: var(--color-muted);
      font-size: clamp(15px, 2.2vw, 17px); margin: 0 0 40px; }
    section { margin: 0 0 40px; }
    h2 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(20px, 3vw, 26px);
      letter-spacing: -.01em; margin: 0 0 6px; }
    .sous { font-family: var(--font-serif); font-style: italic; color: var(--color-muted);
      font-size: 15.5px; margin: 0 0 14px; }
    .texte { font-family: var(--font-serif); font-size: clamp(16px, 2.2vw, 18px); line-height: 1.72; }
    .texte :global(p) { margin: 0 0 1em; }
    .object { font-family: var(--font-mono); font-size: 12px; color: var(--color-muted);
      border-top: 1px solid var(--color-hair); padding-top: 20px; line-height: 1.9;
      display: flex; justify-content: space-between; align-items: baseline; }
    .gloss { color: var(--color-ocre); text-decoration: none; }
    .gloss:hover { text-decoration: underline; text-underline-offset: 3px; }
  </style>
</Base>
