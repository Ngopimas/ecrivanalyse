---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { frDate, participant, quintesseObject, modeLabel, slug, proseHtml, prosePlain, u } from '../../lib/format';

export async function getStaticPaths() {
  // lines can be empty: a "ghost" séance record whose quinte was never
  // published online (quintesse bought, text only in a print recueil) —
  // the page then states that instead of showing a quinte
  const all = (await getCollection('quintes'))
    .filter((q) => q.data.lines.length > 0 || q.data.participant_role)
    .sort((a, b) => (a.data.id ?? 0) - (b.data.id ?? 0));
  const byQuinte = new Map();
  for (const c of await getCollection('comments')) {
    const list = byQuinte.get(c.data.quinte) ?? [];
    list.push(c.data);
    byQuinte.set(c.data.quinte, list);
  }
  for (const list of byQuinte.values()) list.sort((a, b) => a.date.localeCompare(b.date));
  return all.map((q, i) => ({
    params: { id: q.id },
    props: {
      q: q.data,
      qid: q.id,
      comments: byQuinte.get(q.id) ?? [],
      prev: all[i - 1]?.id ?? null,
      next: all[i + 1]?.id ?? null,
    },
  }));
}

const { q, qid, comments, prev, next } = Astro.props;

// French elision glues the next word into one Pagefind token: "d’imam" → "dimam",
// so "imam" isn't findable on its own (and misses fall back to loose letter matches).
// Index an apostrophe-split copy of the text — visible text keeps its typography.
const deElide = (s: unknown) => (s ?? '').toString().replace(/[’']/g, '$& ');
const searchExtra = [q.title, q.soustitre, ...(q.lines ?? []), prosePlain(q.prose ?? ''),
  participant(q), q.collection,
  ...comments.map((c) => c.text)].filter(Boolean).map(deElide).join('  ');

// year · quintesse number, exposed to Pagefind — the search results' mono column
const rMeta = [q.date ? String(q.date).slice(0, 4) : null, q.quintesse_num].filter(Boolean).join(' · ');

// the ghost note, when the quinte itself was never put online. The recueil
// « Faire une quinte de tout » has its presentation on /editions - link it.
const ghost = q.lines.length === 0;
const ghostNote = ghost
  ? `La quinte n'a pas été mise en ligne${q.recueil ? ` : elle se lit dans le recueil « ${q.recueil} »` : ''}.`
  : '';
const recueilHref = ghost && q.recueil && slug(q.recueil) === 'faire-une-quinte-de-tout'
  ? u('/editions#faire-une-quinte-de-tout') : '';

// Hybrid pages (154): the quinte sits INSIDE the prose, where the original
// placed it (the <quinte> marker set by gen-content.py; defaults to the end),
// and at reading size - on the original page it was part of the text flow,
// not a display block. The fitted treatment is for standalone quintes.
const [proseBefore, proseAfter = ''] = (q.prose ?? '').split(/\n*<quinte>\n*/);
const inProse = Boolean(q.prose);
---
<Base
  title={`« ${q.title} » - Écrivanalyse`}
  description={q.soustitre || q.lines.join(' / ') || ghostNote}
  ogImage={ghost ? '/og/default.png' : `/og/${qid}.png`}
  ogImageAlt={`La quinte « ${q.title} »`}
  ogType="article"
>
  <div class="wrap">
    <main data-pagefind-body>
      <h1 transition:name="qtitle">{q.title}</h1>
      {q.soustitre && <p class="desc">{q.soustitre}</p>}
      <!-- data-pagefind-ignore: the collection is indexed via .pf-extra; leaving
           the breadcrumb indexable made every excerpt start with its label -->
      <div class="breadcrumb" data-pagefind-ignore>
        {q.collection && <a class="col" href={u(`/collection/${slug(q.collection)}`)}>«&#8239;{q.collection}&#8239;»</a>}
        {modeLabel(q.mode) && <span> · {modeLabel(q.mode)}</span>}
      </div>

      {proseBefore && <div class="prose" set:html={proseHtml(proseBefore)} />}

      {!ghost ? (
        <div class:list={['quinte', 'enter', { inprose: inProse }]} transition:name="quinte" data-pagefind-meta={rMeta ? `r:${rMeta}` : undefined}>
          <!-- the {' '} keeps Pagefind from jamming line ends together ("bleue,à")
               in excerpts; between block spans it never renders -->
          {q.lines.map((l, i) => <><span class="ln" style={`--i:${i}`}>{l}</span>{' '}</>)}
        </div>
      ) : (
        <p class="ghost" transition:name="quinte" data-pagefind-meta={rMeta ? `r:${rMeta}` : undefined}>
          {recueilHref
            ? <>La quinte n'a pas été mise en ligne&#8239;: elle se lit dans le recueil <a href={recueilHref}>«&#8239;{q.recueil}&#8239;»</a>.</>
            : ghostNote}
        </p>
      )}

      {proseAfter && <div class="prose after" set:html={proseHtml(proseAfter)} />}

      {q.image && (
        <figure class="photo">
          <img src={u(q.image)} alt={q.image_caption || `Photographie de « ${q.title} »`} loading="lazy" decoding="async" />
          {q.image_caption && <figcaption>{q.image_caption}</figcaption>}
        </figure>
      )}

      <div class="object">
        {participant(q) && <div class="who oe">{participant(q)}</div>}
        {quintesseObject(q) && <div class="obj">{quintesseObject(q)}</div>}
        <div class="byline">{q.author} · {frDate(q.date)}</div>
        <div class="obj-actions">
          <button class="share" type="button" data-title={q.title}>partager</button>
          <a class="gloss" href={u('/projet#quintesse')}>qu'est-ce qu'une quintesse&#8239;?</a>
        </div>
      </div>

      {comments.length > 0 && (
        <section class="reponses" id="reponses">
          <h2>{comments.length} réponse{comments.length > 1 ? 's' : ''}</h2>
          {comments.map((c) => (
            <article class="rep">
              <div class="rep-meta">{c.author || 'anonyme'} · {frDate(c.date.slice(0, 10))}</div>
              {c.title && c.title !== q.title && <p class="rep-title">«&#8239;{c.title}&#8239;»</p>}
              <div class="rep-text">{c.text}</div>
            </article>
          ))}
        </section>
      )}

      <section class="repondre">
        <h2>répondre</h2>
        <p class="merci" id="merci">Merci. Votre message a été envoyé&nbsp;: il sera publié après lecture.</p>
        <form method="post" action={u('/api/comment')}>
          <input type="hidden" name="quinte" value={qid} />
          <input type="hidden" name="title" value={q.title} />
          <p class="hp" aria-hidden="true">
            <label>Ne pas remplir <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
          </p>
          <label class="lab" for="rep-nom">votre nom</label>
          <input id="rep-nom" type="text" name="author" maxlength="80" autocomplete="name" />
          <label class="lab" for="rep-msg">votre message</label>
          <textarea id="rep-msg" name="text" required maxlength="2000" rows="5"></textarea>
          <div class="send">
            <button type="submit">envoyer</button>
            <span class="send-note">publié après lecture</span>
          </div>
        </form>
      </section>

      <nav class="pager">
        {prev ? <a rel="prev" href={u(`/quinte/${prev}`)}>← précédente</a> : <span></span>}
        <a class="hasard" href={u('/hasard')} data-astro-reload>rencontre au hasard ↻</a>
        {next ? <a rel="next" href={u(`/quinte/${next}`)}>suivante →</a> : <span></span>}
      </nav>

      <div class="pf-extra" aria-hidden="true">{searchExtra}</div>
      <span class="pf-extra" data-pagefind-filter="type" aria-hidden="true">quinte</span>
    </main>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: q.title,
    author: { '@type': 'Person', name: q.author },
    ...(q.date ? { datePublished: q.date } : {}),
    ...(q.soustitre ? { description: q.soustitre } : {}),
    inLanguage: 'fr',
  })} />

  <style>
    .wrap { max-width: 760px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 32px) 80px; }
    header { display: flex; justify-content: space-between; align-items: center; padding: clamp(20px, 4vw, 34px) 0; }
    .brand { font-family: var(--font-serif); font-size: 19px; text-decoration: none; }
    nav { display: flex; gap: 20px; align-items: center; font-size: 13.5px; color: var(--color-muted); }
    nav a { text-decoration: none; } nav a:hover { color: var(--color-ocre); }
    .iconbtn { background: none; border: none; cursor: pointer; color: var(--color-muted); font-size: 15px; }

    main { padding-top: 0; }
    .breadcrumb { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em;
      color: var(--color-muted); margin: 0 0 36px; }
    .breadcrumb .oe { color: var(--color-ocre); }
    .breadcrumb .col { color: inherit; text-decoration: none; }
    .breadcrumb .col:hover { color: var(--color-ocre); }
    h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(28px, 5vw, 42px);
      letter-spacing: -.01em; margin: clamp(18px, 4vw, 32px) 0 8px; }
    .desc { font-family: var(--font-serif); font-style: italic; color: var(--color-muted);
      font-size: clamp(16px, 2.2vw, 19px); margin: 0 0 14px; }
    /* prose the original page set around the quinte (hybrid pages like 154) */
    .prose { font-family: var(--font-serif); font-weight: 400; font-size: clamp(16px, 2.2vw, 18px);
      line-height: 1.7; margin: 36px 0 0; }
    .prose :global(p) { margin: 0 0 1em; }
    .prose.after { margin-top: 0; }
    /* inside prose, the quinte keeps the reading voice: same size and weight,
       part of the text flow (the fitted display treatment is for standalone
       quintes - the inline fit script skips .inprose) */
    .quinte.inprose { font-size: clamp(16px, 2.2vw, 18px); font-weight: 400;
      line-height: 1.7; margin: 0 0 44px; }
    /* the quinte was never put online: say so, in the reading voice */
    .ghost { font-family: var(--font-serif); font-style: italic; font-size: clamp(17px, 2.4vw, 20px);
      line-height: 1.7; color: var(--color-muted); margin: 44px 0 52px; }
    .ghost a { color: var(--color-ocre); text-decoration: none; }
    .ghost a:hover { text-decoration: underline; text-underline-offset: 3px; }
    .quinte { font-family: var(--font-serif); font-weight: 300; font-size: clamp(21px, 3vw, 28px);
      line-height: 1.72; margin: 36px 0 44px; }
    /* entrance for direct arrivals only (shared link, refresh): the lines ink in
       one by one. Router navigations get the title/body morph instead — the
       rerun script strips .enter when window.__eaNavigated is set. Gated on
       html.js so no-JS visitors always see the text. */
    :global(html.js) .quinte.enter .ln {
      opacity: 0;
      animation: eaLnIn .55s cubic-bezier(.22, .08, .26, 1) both;
      animation-delay: calc(.1s + var(--i, 0) * .09s);
    }
    :global(html.js) .quinte.enter ~ .object {
      opacity: 0;
      animation: eaLnIn .9s ease-out .8s both;
    }
    @keyframes eaLnIn { to { opacity: 1; } }
    @media (prefers-reduced-motion: reduce) {
      :global(html.js) .quinte.enter .ln,
      :global(html.js) .quinte.enter ~ .object { animation: none; opacity: 1; }
    }
    /* each stored line = one visual line; a word is never split or hyphenated.
       The inline fit script scales the font so the longest line fits the column. */
    .quinte .ln { display: block; white-space: nowrap; word-break: keep-all; hyphens: none; }
    /* apostrophe-split copy for Pagefind (see frontmatter). Visually hidden but NOT
       display:none, so Pagefind still indexes its text. */
    .pf-extra { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); clip-path: inset(50%); white-space: nowrap; border: 0; }
    /* the photograph a page carried (190): shown at its captured size, a print
       pinned beside the quinte, not a hero image */
    .photo { margin: 0 0 44px; }
    .photo img { max-width: min(100%, 260px); height: auto; border: 1px solid var(--color-hair); }
    .photo figcaption { font-family: var(--font-mono); font-size: 11px; letter-spacing: .04em;
      color: var(--color-muted); margin-top: 10px; }
    .object { font-family: var(--font-mono); font-size: 12px; color: var(--color-muted);
      border-top: 1px solid var(--color-hair); padding-top: 20px; line-height: 1.9; }
    .object .oe { color: var(--color-ocre); }
    .obj-actions { display: flex; gap: 22px; align-items: baseline; }
    .share { font-family: var(--font-mono); font-size: 12px; letter-spacing: .05em;
      background: none; border: none; cursor: pointer;
      /* padding + negative margins: a finger-sized hit box, same visual position */
      padding: 12px 2px 12px 0; margin: -6px 0 -12px;
      color: var(--color-muted); text-decoration: underline; text-underline-offset: 3px; }
    .share:hover { color: var(--color-ocre); }
    .gloss { font-family: var(--font-serif); font-style: italic; font-size: 13.5px;
      color: var(--color-muted); text-decoration: none;
      padding: 12px 2px; margin: -6px 0 -12px; }
    .gloss:hover { color: var(--color-ocre); text-decoration: underline; text-underline-offset: 3px; }
    .reponses, .repondre { border-top: 1px solid var(--color-hair); margin-top: 44px; padding-top: 18px; }
    .reponses h2, .repondre h2 { font-family: var(--font-mono); font-weight: 400; font-size: 11px;
      letter-spacing: .08em; color: var(--color-muted); margin: 0 0 24px; }
    .rep { margin: 0 0 32px; }
    .rep:last-of-type { margin-bottom: 8px; }
    .rep-meta { font-family: var(--font-mono); font-size: 12px; color: var(--color-muted); margin: 0 0 8px; }
    .rep-title { font-family: var(--font-serif); font-style: italic; font-size: 16px; margin: 0 0 6px; }
    .rep-text { font-family: var(--font-serif); font-size: 16.5px; line-height: 1.65; white-space: pre-line; }

    .repondre form { display: grid; gap: 10px; }
    .lab { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; color: var(--color-muted); }
    .repondre input[type="text"], .repondre textarea { width: 100%; font-family: var(--font-serif);
      font-size: 16px; color: var(--color-ink); background: var(--color-paper-raised);
      border: 1px solid var(--color-hair); border-radius: 2px; padding: 10px 12px; }
    .repondre input[type="text"]:focus-visible, .repondre textarea:focus-visible {
      outline: 1px solid var(--color-ocre); outline-offset: -1px; }
    .repondre textarea { resize: vertical; min-height: 120px; line-height: 1.6; }
    .send { display: flex; align-items: center; gap: 14px; margin-top: 4px; }
    .send button { font-family: var(--font-mono); font-size: 12px; letter-spacing: .06em;
      padding: 9px 20px; background: none; border: 1px solid var(--color-ink); border-radius: 2px;
      color: var(--color-ink); cursor: pointer; }
    .send button:hover { border-color: var(--color-ocre); color: var(--color-ocre); }
    .send-note { font-family: var(--font-serif); font-style: italic; font-size: 13.5px; color: var(--color-muted); }
    /* offscreen honeypot — bots fill it, humans never see it */
    .hp { position: absolute; left: -9999px; margin: 0; }
    /* the endpoint redirects back to #merci: message appears, form disappears */
    .merci { display: none; font-family: var(--font-serif); font-style: italic;
      font-size: 16px; color: var(--color-ocre); margin: 0 0 8px; }
    .merci:target { display: block; }
    .merci:target ~ form { display: none; }

    /* printed, a quinte page becomes a quintesse again: just the text on paper,
       a museum label as colophon */
    @media print {
      :global(.site-header), .breadcrumb, .reponses, .repondre, .pager,
      .obj-actions, .pf-extra { display: none !important; }
      :global(body) { background: #fff !important; color: #111 !important; }
      .wrap { max-width: none; padding: 0; }
      h1 { margin-top: 22mm; color: #111; }
      .desc { color: #555; }
      .quinte { font-size: 17pt !important; white-space: normal !important;
        margin: 16mm 0 20mm; color: #111; }
      .quinte .ln { opacity: 1 !important; animation: none !important;
        white-space: normal !important; }
      @page { margin: 22mm 24mm; }
      .object { opacity: 1 !important; animation: none !important;
        border-top-color: #ddd; color: #555; }
      .object .oe { color: #8a3a24; }
      .byline::after { content: " · ecrivanalyse.net"; }
    }

    .pager { display: flex; justify-content: space-between; margin-top: 48px;
      font-family: var(--font-serif); font-style: italic; font-size: 15px; }
    .pager a { color: var(--color-ocre); text-decoration: none; padding: 10px 2px; margin: -10px 0; }
    .pager a:hover { text-decoration: underline; }
    /* narrow screens: prev/next share a row, hasard sits centered below.
       Positional selectors so the empty placeholder spans keep their side. */
    @media (max-width: 560px) {
      .pager { flex-wrap: wrap; row-gap: 10px; }
      .pager > :first-child { order: 1; }
      .pager > :last-child { order: 2; }
      .pager .hasard { order: 3; flex-basis: 100%; text-align: center; }
    }
  </style>

  <script is:inline data-astro-rerun>
    (() => {
    const MIN = 18, MAX = 32, REF = 100;   // font-size floor / ceiling (px), measuring size
    // Scale the quinte so its longest line stays on one line within the column;
    // below MIN px (very long line / narrow screen) it wraps rather than overflow.
    // in-site navigation: the morph is the entrance — drop the line stagger
    if (window.__eaNavigated) document.querySelector('.quinte')?.classList.remove('enter');
    function fit() {
      const q = document.querySelector('.quinte');
      if (!q || q.classList.contains('inprose')) return;  // reading-size, inside prose
      const lines = q.querySelectorAll('.ln');
      if (!lines.length) return;
      const avail = q.clientWidth;
      if (!avail) return;
      q.style.whiteSpace = 'nowrap';
      q.style.fontSize = REF + 'px';                    // measure with every line overflowing, so scrollWidth is exact
      let widest = 0;
      lines.forEach((l) => { if (l.scrollWidth > widest) widest = l.scrollWidth; });
      if (!widest) { q.style.fontSize = ''; return; }
      const ideal = REF * avail / widest;
      if (ideal >= MIN) {
        q.style.whiteSpace = 'nowrap';
        q.style.fontSize = Math.min(MAX, ideal).toFixed(1) + 'px';
      } else {
        q.style.whiteSpace = 'normal';                  // graceful floor: wrap instead of overflow
        q.style.fontSize = MIN + 'px';
      }
    }
    fit();
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(fit);
    if (!window.__eaQuinteResize) {
      window.__eaQuinteResize = true;
      let raf = 0;
      window.addEventListener('resize', () => { cancelAnimationFrame(raf); raf = requestAnimationFrame(fit); });
    }
    })();
  </script>

  <script is:inline data-astro-rerun>
    (() => {
    // « partager »: native share sheet where available, else copy the link.
    // onclick assignment (not addEventListener) so re-running after a view
    // transition never double-binds.
    const b = document.querySelector('.share');
    if (!b) return;
    b.onclick = async () => {
      const url = location.origin + location.pathname;
      const title = '« ' + b.dataset.title + ' » - Écrivanalyse';
      if (navigator.share) {
        try { await navigator.share({ title, url }); } catch {}
      } else if (navigator.clipboard) {
        await navigator.clipboard.writeText(url);
        b.textContent = 'lien copié';
        setTimeout(() => { b.textContent = 'partager'; }, 2000);
      }
    };
    })();
  </script>

  <script is:inline data-astro-rerun>
    (() => {
    // Leaf through the archive: ← / → keys, horizontal swipe on touch.
    // Handlers live on document behind window.__ea* guards (view transitions
    // re-run this script; remove-then-add keeps exactly one binding), and
    // navigation clicks the real pager link so the ClientRouter animates it.
    const go = (dir) => document.querySelector('.pager a[rel="' + dir + '"]')?.click();

    if (window.__eaQKey) document.removeEventListener('keydown', window.__eaQKey);
    window.__eaQKey = (e) => {
      if (!document.querySelector('.pager')) return;
      if (e.altKey || e.metaKey || e.ctrlKey || e.shiftKey) return;
      if (e.target.closest?.('input, textarea, select')) return;
      if (e.key === 'ArrowLeft') go('prev');
      else if (e.key === 'ArrowRight') go('next');
    };
    document.addEventListener('keydown', window.__eaQKey);

    let x0 = 0, y0 = 0, t0 = 0;
    if (window.__eaQTs) document.removeEventListener('touchstart', window.__eaQTs);
    window.__eaQTs = (e) => {
      const t = e.touches[0];
      x0 = t.clientX; y0 = t.clientY; t0 = Date.now();
    };
    document.addEventListener('touchstart', window.__eaQTs, { passive: true });

    if (window.__eaQTe) document.removeEventListener('touchend', window.__eaQTe);
    window.__eaQTe = (e) => {
      if (!document.querySelector('.pager')) return;
      if (e.target.closest?.('input, textarea, a, button')) return;
      const t = e.changedTouches[0];
      const dx = t.clientX - x0, dy = t.clientY - y0;
      // quick, decisive, and clearly horizontal — scrolls and long-presses don't qualify
      if (Date.now() - t0 < 600 && Math.abs(dx) > 70 && Math.abs(dx) > 2.2 * Math.abs(dy))
        go(dx < 0 ? 'next' : 'prev');
    };
    document.addEventListener('touchend', window.__eaQTe, { passive: true });
    })();
  </script>
</Base>
