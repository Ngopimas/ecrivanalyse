---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { frDate, participant, quintesseObject, modeLabel, slug } from '../../lib/format';

export async function getStaticPaths() {
  const all = (await getCollection('quintes'))
    .filter((q) => q.data.lines.length > 0)
    .sort((a, b) => (a.data.id ?? 0) - (b.data.id ?? 0));
  const byQuinte = new Map();
  for (const c of await getCollection('comments')) {
    const list = byQuinte.get(c.data.quinte) ?? [];
    list.push(c.data);
    byQuinte.set(c.data.quinte, list);
  }
  for (const list of byQuinte.values()) list.sort((a, b) => a.date.localeCompare(b.date));
  return all.map((q, i) => ({
    params: { id: q.id },
    props: {
      q: q.data,
      qid: q.id,
      comments: byQuinte.get(q.id) ?? [],
      prev: all[i - 1]?.id ?? null,
      next: all[i + 1]?.id ?? null,
    },
  }));
}

const { q, qid, comments, prev, next } = Astro.props;

// French elision glues the next word into one Pagefind token: "d’imam" → "dimam",
// so "imam" isn't findable on its own (and misses fall back to loose letter matches).
// Index an apostrophe-split copy of the text — visible text keeps its typography.
const deElide = (s: unknown) => (s ?? '').toString().replace(/[’']/g, '$& ');
const searchExtra = [q.title, q.soustitre, ...(q.lines ?? []), participant(q), q.collection,
  ...comments.map((c) => c.text)].filter(Boolean).map(deElide).join('  ');
---
<Base
  title={`« ${q.title} » - Écrivanalyse`}
  description={q.soustitre || q.lines.join(' / ')}
  ogImage={`/og/${qid}.png`}
  ogImageAlt={`La quinte « ${q.title} »`}
  ogType="article"
>
  <div class="wrap">
    <main data-pagefind-body>
      <h1>{q.title}</h1>
      {q.soustitre && <p class="desc">{q.soustitre}</p>}
      <div class="breadcrumb">
        {q.collection && <a class="col" href={`/collection/${slug(q.collection)}`}>«&#8239;{q.collection}&#8239;»</a>}
        {modeLabel(q.mode) && <span> · {modeLabel(q.mode)}</span>}
      </div>

      <div class="quinte">
        {q.lines.map((l) => <span class="ln">{l}</span>)}
      </div>

      <div class="object">
        {participant(q) && <div class="who oe">{participant(q)}</div>}
        {quintesseObject(q) && <div class="obj">{quintesseObject(q)}</div>}
        <div class="byline">{q.author} · {frDate(q.date)}</div>
        <button class="share" type="button" data-title={q.title}>partager</button>
      </div>

      {comments.length > 0 && (
        <section class="reponses" id="reponses">
          <h2>{comments.length} réponse{comments.length > 1 ? 's' : ''}</h2>
          {comments.map((c) => (
            <article class="rep">
              <div class="rep-meta">{c.author || 'anonyme'} · {frDate(c.date.slice(0, 10))}</div>
              {c.title && c.title !== q.title && <p class="rep-title">«&#8239;{c.title}&#8239;»</p>}
              <div class="rep-text">{c.text}</div>
            </article>
          ))}
        </section>
      )}

      <section class="repondre">
        <h2>répondre</h2>
        <p class="merci" id="merci">Merci. Votre message a été envoyé&nbsp;: il sera publié après lecture.</p>
        <form method="post" action="/api/comment">
          <input type="hidden" name="quinte" value={qid} />
          <input type="hidden" name="title" value={q.title} />
          <p class="hp" aria-hidden="true">
            <label>Ne pas remplir <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
          </p>
          <label class="lab" for="rep-nom">votre nom</label>
          <input id="rep-nom" type="text" name="author" maxlength="80" autocomplete="name" />
          <label class="lab" for="rep-msg">votre message</label>
          <textarea id="rep-msg" name="text" required maxlength="2000" rows="5"></textarea>
          <div class="send">
            <button type="submit">envoyer</button>
            <span class="send-note">publié après lecture</span>
          </div>
        </form>
      </section>

      <nav class="pager">
        {prev ? <a href={`/quinte/${prev}`}>← précédente</a> : <span></span>}
        <a href="/hasard" data-astro-reload>rencontre au hasard ↻</a>
        {next ? <a href={`/quinte/${next}`}>suivante →</a> : <span></span>}
      </nav>

      <div class="pf-extra" aria-hidden="true">{searchExtra}</div>
    </main>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: q.title,
    author: { '@type': 'Person', name: q.author },
    ...(q.date ? { datePublished: q.date } : {}),
    ...(q.soustitre ? { description: q.soustitre } : {}),
    inLanguage: 'fr',
  })} />

  <style>
    .wrap { max-width: 760px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 32px) 80px; }
    header { display: flex; justify-content: space-between; align-items: center; padding: clamp(20px, 4vw, 34px) 0; }
    .brand { font-family: var(--font-serif); font-size: 19px; text-decoration: none; }
    nav { display: flex; gap: 20px; align-items: center; font-size: 13.5px; color: var(--color-muted); }
    nav a { text-decoration: none; } nav a:hover { color: var(--color-ocre); }
    .iconbtn { background: none; border: none; cursor: pointer; color: var(--color-muted); font-size: 15px; }

    main { padding-top: 0; }
    .breadcrumb { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em;
      color: var(--color-muted); margin: 0 0 36px; }
    .breadcrumb .oe { color: var(--color-ocre); }
    .breadcrumb .col { color: inherit; text-decoration: none; }
    .breadcrumb .col:hover { color: var(--color-ocre); }
    h1 { font-family: var(--font-serif); font-weight: 400; font-size: clamp(28px, 5vw, 42px);
      letter-spacing: -.01em; margin: clamp(18px, 4vw, 32px) 0 8px; }
    .desc { font-family: var(--font-serif); font-style: italic; color: var(--color-muted);
      font-size: clamp(16px, 2.2vw, 19px); margin: 0 0 14px; }
    .quinte { font-family: var(--font-serif); font-weight: 300; font-size: clamp(21px, 3vw, 28px);
      line-height: 1.72; margin: 36px 0 44px; }
    /* each stored line = one visual line; a word is never split or hyphenated.
       The inline fit script scales the font so the longest line fits the column. */
    .quinte .ln { display: block; white-space: nowrap; word-break: keep-all; hyphens: none; }
    /* apostrophe-split copy for Pagefind (see frontmatter). Visually hidden but NOT
       display:none, so Pagefind still indexes its text. */
    .pf-extra { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); clip-path: inset(50%); white-space: nowrap; border: 0; }
    .object { font-family: var(--font-mono); font-size: 12px; color: var(--color-muted);
      border-top: 1px solid var(--color-hair); padding-top: 20px; line-height: 1.9; }
    .object .oe { color: var(--color-ocre); }
    .share { font-family: var(--font-mono); font-size: 12px; letter-spacing: .05em;
      background: none; border: none; padding: 0; margin-top: 6px; cursor: pointer;
      color: var(--color-muted); text-decoration: underline; text-underline-offset: 3px; }
    .share:hover { color: var(--color-ocre); }
    .reponses, .repondre { border-top: 1px solid var(--color-hair); margin-top: 44px; padding-top: 18px; }
    .reponses h2, .repondre h2 { font-family: var(--font-mono); font-weight: 400; font-size: 11px;
      letter-spacing: .08em; color: var(--color-muted); margin: 0 0 24px; }
    .rep { margin: 0 0 32px; }
    .rep:last-of-type { margin-bottom: 8px; }
    .rep-meta { font-family: var(--font-mono); font-size: 12px; color: var(--color-muted); margin: 0 0 8px; }
    .rep-title { font-family: var(--font-serif); font-style: italic; font-size: 16px; margin: 0 0 6px; }
    .rep-text { font-family: var(--font-serif); font-size: 16.5px; line-height: 1.65; white-space: pre-line; }

    .repondre form { display: grid; gap: 10px; }
    .lab { font-family: var(--font-mono); font-size: 11px; letter-spacing: .05em; color: var(--color-muted); }
    .repondre input[type="text"], .repondre textarea { width: 100%; font-family: var(--font-serif);
      font-size: 16px; color: var(--color-ink); background: var(--color-paper-raised);
      border: 1px solid var(--color-hair); border-radius: 2px; padding: 10px 12px; }
    .repondre input[type="text"]:focus-visible, .repondre textarea:focus-visible {
      outline: 1px solid var(--color-ocre); outline-offset: -1px; }
    .repondre textarea { resize: vertical; min-height: 120px; line-height: 1.6; }
    .send { display: flex; align-items: center; gap: 14px; margin-top: 4px; }
    .send button { font-family: var(--font-mono); font-size: 12px; letter-spacing: .06em;
      padding: 9px 20px; background: none; border: 1px solid var(--color-ink); border-radius: 2px;
      color: var(--color-ink); cursor: pointer; }
    .send button:hover { border-color: var(--color-ocre); color: var(--color-ocre); }
    .send-note { font-family: var(--font-serif); font-style: italic; font-size: 13.5px; color: var(--color-muted); }
    /* offscreen honeypot — bots fill it, humans never see it */
    .hp { position: absolute; left: -9999px; margin: 0; }
    /* the endpoint redirects back to #merci: message appears, form disappears */
    .merci { display: none; font-family: var(--font-serif); font-style: italic;
      font-size: 16px; color: var(--color-ocre); margin: 0 0 8px; }
    .merci:target { display: block; }
    .merci:target ~ form { display: none; }

    .pager { display: flex; justify-content: space-between; margin-top: 48px;
      font-family: var(--font-serif); font-style: italic; font-size: 15px; }
    .pager a { color: var(--color-ocre); text-decoration: none; }
    .pager a:hover { text-decoration: underline; }
  </style>

  <script is:inline data-astro-rerun>
    (() => {
    const MIN = 18, MAX = 32, REF = 100;   // font-size floor / ceiling (px), measuring size
    // Scale the quinte so its longest line stays on one line within the column;
    // below MIN px (very long line / narrow screen) it wraps rather than overflow.
    function fit() {
      const q = document.querySelector('.quinte');
      if (!q) return;
      const lines = q.querySelectorAll('.ln');
      if (!lines.length) return;
      const avail = q.clientWidth;
      if (!avail) return;
      q.style.whiteSpace = 'nowrap';
      q.style.fontSize = REF + 'px';                    // measure with every line overflowing, so scrollWidth is exact
      let widest = 0;
      lines.forEach((l) => { if (l.scrollWidth > widest) widest = l.scrollWidth; });
      if (!widest) { q.style.fontSize = ''; return; }
      const ideal = REF * avail / widest;
      if (ideal >= MIN) {
        q.style.whiteSpace = 'nowrap';
        q.style.fontSize = Math.min(MAX, ideal).toFixed(1) + 'px';
      } else {
        q.style.whiteSpace = 'normal';                  // graceful floor: wrap instead of overflow
        q.style.fontSize = MIN + 'px';
      }
    }
    fit();
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(fit);
    if (!window.__eaQuinteResize) {
      window.__eaQuinteResize = true;
      let raf = 0;
      window.addEventListener('resize', () => { cancelAnimationFrame(raf); raf = requestAnimationFrame(fit); });
    }
    })();
  </script>

  <script is:inline data-astro-rerun>
    (() => {
    // « partager »: native share sheet where available, else copy the link.
    // onclick assignment (not addEventListener) so re-running after a view
    // transition never double-binds.
    const b = document.querySelector('.share');
    if (!b) return;
    b.onclick = async () => {
      const url = location.origin + location.pathname;
      const title = '« ' + b.dataset.title + ' » — Écrivanalyse';
      if (navigator.share) {
        try { await navigator.share({ title, url }); } catch {}
      } else if (navigator.clipboard) {
        await navigator.clipboard.writeText(url);
        b.textContent = 'lien copié';
        setTimeout(() => { b.textContent = 'partager'; }, 2000);
      }
    };
    })();
  </script>
</Base>
