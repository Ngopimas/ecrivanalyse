                <path class="plan-street plan-street--minor" d="M228.8,67.0 L229.2,65.7 L231.0,59.8 L234.9,46.2" />
                <path class="plan-street plan-street--minor" d="M227.1,92.7 L221.3,117.0 L221.0,118.4 L220.4,120.7 L220.1,122.1" />
                <path class="plan-street plan-street--minor" d="M84.2,110.8 L89.0,98.3 L89.8,96.4" />
                <path class="plan-street plan-street--minor" d="M82.2,116.0 L84.2,110.8" />
                <path class="plan-street plan-street--minor" d="M234.9,46.2 L236.2,41.6 L237.0,38.4" />
                <path class="plan-street plan-street--minor" d="M252.4,72.5 L255.0,64.8 L258.5,52.1 L259.8,46.9 L260.6,43.6" />
                <path class="plan-street" d="M57.6,281.4 L58.8,278.3 L71.4,250.1 L73.7,244.7" />
                <path class="plan-street" d="M175.5,151.1 L179.2,152.3 L202.5,160.2 L205.4,161.2 L208.8,162.3 L317.4,197.6" />
                <path class="plan-street" d="M199.9,-213.0 L181.2,-173.6 L141.3,-88.4 L135.4,-76.1 L118.8,-39.1" />
                <path class="plan-street" d="M122.8,266.8 L127.7,261.0 L143.1,225.9 L174.0,154.7 L175.5,151.1" />
                <path class="plan-street" d="M73.7,244.7 L99.2,255.8 L119.4,264.6 L122.8,266.8" />
                <path class="plan-street" d="M121.5,131.9 L115.8,130.1 L81.0,119.0 L15.2,97.8 L8.6,95.8" />
                <path class="plan-street" d="M220.1,122.1 L218.5,126.4 L206.7,157.7 L205.4,161.2" />
                <path class="plan-street" d="M172.3,-36.2 L186.2,-32.7 L196.9,-28.2 L235.4,-11.2" />
