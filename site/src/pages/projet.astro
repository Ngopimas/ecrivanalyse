                <path class="plan-street" d="M49.0,-12.4 L78.1,-5.2 L125.0,6.7 L232.1,31.1 L322.4,52.5 L396.9,69.6 L440.8,74.9" />
                <path class="plan-street" d="M175.5,151.1 L171.2,149.6 L127.8,134.2 L121.5,131.9" />
