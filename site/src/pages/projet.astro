                 aria-label="Plan des rues autour du Point, 43 rue Notre-Dame-de-Nazareth, Paris 3e (OpenStreetMap)">
              <clipPath id="cc-clip"><rect x="0" y="0" width="300" height="220"/></clipPath>
              <g clip-path="url(#cc-clip)">
                <path class="plan-street plan-street--minor" d="M172.3,-36.2 L190.1,-79.6 L191.0,-80.2 L193.3,-81.5 L234.2,-179.1 L235.7,-182.6" />
