---
// Spectral (Production Type, Paris) — static family; import the true italics
// too, or every italic (the quintes!) would be a synthesized slant
import '@fontsource/spectral/300.css';
import '@fontsource/spectral/400.css';
import '@fontsource/spectral/500.css';
import '@fontsource/spectral/300-italic.css';
import '@fontsource/spectral/400-italic.css';
import '@fontsource-variable/instrument-sans';
import '@fontsource-variable/jetbrains-mono';
import spectralWght from '@fontsource/spectral/files/spectral-latin-400-normal.woff2?url';
import spectralItal from '@fontsource/spectral/files/spectral-latin-400-italic.woff2?url';
import '../styles/global.css';
import Header from '../components/Header.astro';
import { ClientRouter } from 'astro:transitions';
import { u } from '../lib/format';

interface Props {
  title?: string;
  description?: string;
  /** Path to the social card, e.g. `/og/647.png`. */
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  /** The landing owns its own closing composition: it opts out. */
  footer?: boolean;
}
const {
  title = 'Écrivanalyse',
  description = "L'écrivanalyse d'Ivan Joseph - vingt ans de quintes : cinq lignes, cinq mots par ligne, cinq signes de ponctuation.",
  ogImage = '/og/default.png',
  ogImageAlt = 'Écrivanalyse - Ivan Joseph',
  ogType = 'website',
  footer = true,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(u(ogImage), Astro.site);
---
<!doctype html>
<html lang="fr" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#F6F1E7" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1E1A16" />
  <meta property="og:site_name" content="Écrivanalyse" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="sitemap" href={u('/sitemap-index.xml')} />
  <link rel="icon" href={u('/favicon.svg')} type="image/svg+xml" />
  <link rel="icon" href={u('/favicon-96.png')} type="image/png" sizes="96x96" />
  <link rel="apple-touch-icon" href={u('/apple-touch-icon.png')} />
  <link rel="preload" as="font" type="font/woff2" href={spectralWght} crossorigin />
  <link rel="preload" as="font" type="font/woff2" href={spectralItal} crossorigin />
  <script is:inline>
    document.documentElement.classList.add('js');
    const t = localStorage.getItem('ea-theme');
    if (t) document.documentElement.dataset.theme = t;
  </script>
  <ClientRouter />
</head>
<body class="min-h-screen">
  <a class="skip" href="#contenu">Aller au contenu</a>
  <Header />
  <div class="site-body" id="contenu"><slot /></div>

  {footer && (
    <footer class="site-foot">
      <nav aria-label="Pages du site">
        <a href={u('/ecrivanalyse')}>Qu’est-ce que l’écrivanalyse&#8239;?</a>
        <span aria-hidden="true">·</span>
        <a href={u('/editions')}>Les éditions</a>
        <span aria-hidden="true">·</span>
        <a href={u('/hasard')} data-astro-reload>rencontre au hasard&nbsp;↻</a>
      </nav>
    </footer>
  )}
  <style is:global>
    .site-foot { border-top: 1px solid var(--color-hair); margin-top: 24px;
      padding: 26px clamp(20px, 5vw, 32px) calc(30px + env(safe-area-inset-bottom, 0px)); }
    .site-foot nav { max-width: 760px; margin: 0 auto; display: flex; gap: 14px;
      flex-wrap: wrap; justify-content: center; align-items: baseline;
      font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .04em;
      color: var(--color-muted); }
    .site-foot a { color: inherit; text-decoration: none; padding: 8px 2px; margin: -8px 0; }
    .site-foot a:hover { color: var(--color-ocre); }
    @media print { .site-foot { display: none !important; } }
  </style>

  <!-- quiet return trip on the long pages (archive, textes); appears after
       ~1.5 viewports of scroll, so short pages never show it -->
  <button class="ea-top" id="ea-top" type="button" aria-label="Revenir en haut">↑</button>
  <style is:global>
    .ea-top { position: fixed; right: clamp(14px, 3vw, 26px); bottom: clamp(14px, 3vw, 26px);
      z-index: 30; width: 42px; height: 42px; border-radius: 50%;
      border: 1px solid var(--color-hair); background: var(--color-paper-raised);
      color: var(--color-muted); font-family: var(--font-mono); font-size: 15px; line-height: 1;
      cursor: pointer; opacity: 0; visibility: hidden; transform: translateY(6px);
      transition: opacity .3s ease, transform .3s ease, visibility .3s; }
    .ea-top.show { opacity: 1; visibility: visible; transform: none; }
    .ea-top:hover { color: var(--color-ocre); border-color: var(--color-ocre); }
    @media (prefers-reduced-motion: reduce) { .ea-top { transition: none; transform: none; } }
    @media print { .ea-top { display: none !important; } }
  </style>
  <script is:inline data-astro-rerun>
    (() => {
      const b = document.getElementById('ea-top');
      if (!b) return;
      b.onclick = () => window.scrollTo({
        top: 0,
        behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
      });
      if (window.__eaTopScroll) window.removeEventListener('scroll', window.__eaTopScroll);
      window.__eaTopScroll = () => {
        const el = document.getElementById('ea-top');
        if (el) el.classList.toggle('show', window.scrollY > innerHeight * 1.5);
      };
      window.addEventListener('scroll', window.__eaTopScroll, { passive: true });
      window.__eaTopScroll();
    })();
  </script>
  <script is:inline>
    window.toggleTheme = function () {
      const r = document.documentElement;
      const n = r.dataset.theme === 'dark' ? 'light' : 'dark';
      r.dataset.theme = n;
      localStorage.setItem('ea-theme', n);
    };
    // Re-apply the saved theme after each view transition (the incoming page
    // ships with the default light theme in its <html>).
    document.addEventListener('astro:after-swap', () => {
      const t = localStorage.getItem('ea-theme');
      if (t) document.documentElement.dataset.theme = t;
    });
    // Entrance animations are for direct arrivals only; router navigations
    // rely on the shared-element morphs instead. Pages check this flag.
    document.addEventListener('astro:before-swap', () => { window.__eaNavigated = true; });
    // « qtitle » — the title-continuity morph. A clicked list/wall title is
    // named just-in-time and pairs with the destination page's h1, so the
    // title travels from the mass to its page (and back, on browser Back).
    // One name per page: strip it from whatever currently holds it first.
    document.addEventListener('astro:before-preparation', (e) => {
      const src = e.sourceElement;
      if (!(src instanceof Element)) return;
      const a = src.closest('a[href]');
      if (!a) return;
      const t = a.querySelector('[data-vt-title]') || (a.matches('[data-vt-title], .wt') ? a : null);
      if (!t) return;
      document.querySelectorAll('h1, [data-vt-title], #q-title, .wt.lit').forEach((el) => {
        if (getComputedStyle(el).viewTransitionName === 'qtitle') el.style.viewTransitionName = 'none';
      });
      t.style.viewTransitionName = 'qtitle';
    });
  </script>
</body>
</html>
